rules_version = '2';

/**
 * 학급 STATUS 앱용 규칙
 *
 * 아래 YOUR_TEACHER_AUTH_UID 를 firebase-config.js 의 teacherFirestoreUid 와
 * 동일한 값(선생님 Firebase Authentication UID)으로 바꾼 뒤 배포하세요.
 *
 *   firebase deploy --only firestore:rules
 *
 * - 선생님: 본인 users/{본인uid}/classStatus/* 에 읽기/쓰기
 * - 익명 학생: 위 선생 UID 경로에만 읽기/쓰기 (아바타·PIN 등이 클라우드에 반영됨)
 */
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/classStatus/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        userId == '4acblY6SDDcflRd2H6HpzwtWVvi1'
      );
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
